COMPOSE_ENV_FILE=.env.compose

POSTGRES_DB=worldkyc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

DB_BIND_HOST=127.0.0.1
DB_BIND_PORT=5432
DB_DATA_DIR=./pgdata

APP_BIND_HOST=127.0.0.1
APP_BIND_PORT=8080
APP_IMAGE_REPOSITORY=ghcr.io/14zy/worldkycproject
APP_IMAGE_TAG=latest
MAILCOW_NETWORK_NAME=mailcowdockerized_mailcow-network

BOT_TOKEN=replace-me
TMA_URL=https://example.com/tma
AUTHORIZED_TOKEN=replace-me
WKYC_BASE_URL=https://www.bizcurrency.com:20500
WKYC_VLINK_BASE_URL=https://app.worldkyc.com/vl/
WKYC_CALLER_ID=00000000-0000-0000-0000-000000000000
WKYC_TIMEOUT_SECONDS=15
WKYC_REFRESH_WINDOW_SECONDS=300
WKYC_REFRESH_SCAN_INTERVAL_SECONDS=60
WKYC_REFRESH_TOKEN_DEFAULT_TTL_HOURS=24
WKYC_VLINK_SYNC_INTERVAL_SECONDS=900

IMAP_HOST=dovecot
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_MAILBOX=INBOX
IMAP_USE_SSL=true
IMAP_POLL_INTERVAL_SECONDS=60

RESEND_API_KEY=replace-me
RESEND_BASE_URL=https://api.resend.com
RESEND_TIMEOUT_SECONDS=15
MAIL_FROM_DOMAIN=tonstealthid.com
